# DFA-Auto-Flow 환경변수 예시 — 실제 값은 .env / .env.local 에 넣으세요 (git 커밋 금지)

# Supabase (샘플 동기화 사용 시)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
# 또는 VITE_ 접두 사용 가능
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# AI API 키 (선택 / dev 폴백)
# 기본은 앱 우측 상단 🔑 버튼에서 브라우저(localStorage)에 직접 입력합니다.
# 매번 입력이 번거로운 개발 환경에서만 아래 dev 폴백을 사용하세요.
# VITE_GEMINI_API_KEY=
# VITE_OPENAI_API_KEY=
# VITE_ANTHROPIC_API_KEY=
